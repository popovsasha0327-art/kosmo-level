ProphecySystem.Prophet
{"repeatable":false,"prophecyStrings":["{\"performers\":[3],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":true,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"А ой, вы кто?                          Или знаю кто это\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Я Люми, твоя Лучшая, (по факту) подруга.\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[3],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":true,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"А фух. А то я думала, что это опять Фиолетовая Кошка\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Я могу подойти к тебе ближе?\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[3],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":true,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Аэаэ?? Да ок.\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[1],\"lumiMoving\":true,\"redMoving\":false,\"greenMoving\":false,\"blueMoving\":false,\"purpleMoving\":false,\"moveType\":10,\"duration\":0.0,\"runParallel\":false}"],"prophecyTypeStrings":["ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.MoveProphecy"],"removePlayerControlUntilTold":true,"companionActivated":false}

