king\":false,\"purpleTalking\":false,\"dialogue\":\"Ты хочешь сказать что Фоилетовых Котов двое что-ли?\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[2],\"lumiTalking\":false,\"redTalking\":true,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Да! Их вовсе 5-10 штук может быть!\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Короче по дороге подскажешь что это! А сейчас ПОГНАЛИ!\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"Ха они не долумаются посмотреть на верх!\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":true}","{\"performers\":[1,2],\"lumiMoving\":true,\"redMoving\":true,\"greenMoving\":false,\"blueMoving\":false,\"purpleMoving\":false,\"moveType\":20,\"duration\":0.0,\"runParallel\":false}"],"prophecyTypeStrings":["ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.MoveProphecy"],"removePlayerControlUntilTold":true,"companionActivated":false}

