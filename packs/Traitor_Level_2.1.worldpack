ProphecySystem.Prophet
{"repeatable":false,"prophecyStrings":["{\"performers\":[1],\"lumiMoving\":true,\"redMoving\":false,\"greenMoving\":false,\"blueMoving\":false,\"purpleMoving\":false,\"moveType\":0,\"duration\":0.0,\"runParallel\":false}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Меня, попросили тебя забрать, я пыталась и меня поймал Фиолетовая Кошка, я потеряла сознание и очнулась иза Жужания. В клетке.\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"У меня ещё была кнопка, для управления лазерами. Тут я этого не вижу\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[3],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":true,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Да, у меня никаких кнопок, нету. Об лазеры ударялся уж слишком... С последствиями останусь...\",\"endWait\":28.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Нам нужно сбежать отсюда, скорее\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Я могу перенастроить Лазера, что-бы их отключить?\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[3],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":true,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Гениальная Идея!\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"По желай удачи!\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"duration\":70.0}","{\"performers\":[3],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":true,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"У тебя там все получается?\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"duration\":48.0}","{\"connectedButtonGUID\":\"9dec1109-686e-475f-b7bc-7bbffa0b7453\"}","{\"connectedButtonGUID\":\"1a62e924-7872-4a37-886a-16218551e66e\"}","{\"performers\":[3],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":true,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"О ура!\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1,3],\"lumiMoving\":true,\"redMoving\":false,\"greenMoving\":true,\"blueMoving\":false,\"purpleMoving\":false,\"moveType\":10,\"duration\":0.0,\"runParallel\":false}"],"prophecyTypeStrings":["ProphecySystem.MoveProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.WaitProphecy","ProphecySystem.TalkProphecy","ProphecySystem.WaitProphecy","ProphecySystem.ButtonProphecy","ProphecySystem.ButtonProphecy","ProphecySystem.TalkProphecy","ProphecySystem.MoveProphecy"],"removePlayerControlUntilTold":true,"companionActivated":false}

