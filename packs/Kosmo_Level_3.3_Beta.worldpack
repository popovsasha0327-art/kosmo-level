ProphecySystem.Prophet
{"repeatable":false,"prophecyStrings":["{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"Ты прошла уже 3 испытания\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"Но я не думала что ты так быстро пройдешь эти 3 готовых испытаний.\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"Я занервничала потому что ты так близко была.\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"Но я придумала план, так как я имею право управлять тобой, то я тебя убью\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"В смысле, друзей отпускать а меня убивать?\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"А как тогда зелёная, красная и синяя кошка вышли на свободу?\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"Я тебе одну тайну скажу, я соврала. На самом деле они тоже в лаве. Ха-ха-ха\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"И у тебя не будет шансов на спасение.\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1],\"lumiFace\":true,\"redFace\":false,\"greenFace\":false,\"blueFace\":false,\"faceType\":6,\"duration\":100.0,\"runParallel\":true}","{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"3\",\"endWait\":10.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"2\",\"endWait\":10.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"connectedButtonGUID\":\"c8139b9b-1ca9-442b-a87c-cb3c5f7b085b\"}","{\"performers\":[5],\"lumiMoving\":false,\"redMoving\":false,\"greenMoving\":false,\"blueMoving\":false,\"purpleMoving\":true,\"moveType\":101,\"duration\":0.0,\"runParallel\":false}"],"prophecyTypeStrings":["ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.FaceProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.ButtonProphecy","ProphecySystem.MoveProphecy"],"removePlayerControlUntilTold":true,"companionActivated":false}

