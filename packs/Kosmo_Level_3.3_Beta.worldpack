{"repeatable":false,"prophecyStrings":["{\"performers\":[1],\"lumiMoving\":true,\"redMoving\":false,\"greenMoving\":false,\"blueMoving\":false,\"purpleMoving\":false,\"moveType\":0,\"duration\":0.0,\"runParallel\":true}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"Не иди туда!\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":true}","{\"duration\":5.0}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"Ну что ты наконец то попалась, Люми.\",\"endWait\":34.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"Я наконец то дождалась твоего прохождения!\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":true}","{\"effectType\":1,\"duration\":0.0,\"runParallel\":false}","{\"duration\":4.0}","{\"themeID\":19}","{\"duration\":2.0}","{\"effectType\":0,\"duration\":0.0,\"runParallel\":false}","{\"duration\":25.0}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"Твои настоящие друзья мне просто помогли и я их отпустила раньше на свободу!\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"Здесь я вижу что устала, Да?\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[1],\"lumiEmoting\":true,\"redEmoting\":false,\"greenEmoting\":false,\"blueEmoting\":false,\"purpleEmoting\":false,\"emoteType\":5,\"duration\":10.0,\"runParallel\":true}","{\"duration\":5.0}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"А ну понятно что твое прохождение было таким интересным, что аж заперла меня в 8 мире!\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"Ну нечего страшного, я пыталась выбратся в 8 мире, ты будешь в 12 это делать!\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[1],\"lumiEmoting\":true,\"redEmoting\":false,\"greenEmoting\":false,\"blueEmoting\":false,\"purpleEmoting\":false,\"emoteType\":3,\"duration\":10.0,\"runParallel\":false}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Что ты имеешь ввиду?\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"А в таком, я тебе тоже должна что то взаимно делать?\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[1],\"lumiMoving\":true,\"redMoving\":false,\"greenMoving\":false,\"blueMoving\":false,\"purpleMoving\":false,\"moveType\":20,\"duration\":0.0,\"runParallel\":false}"],"prophecyTypeStrings":["ProphecySystem.MoveProphecy","ProphecySystem.TalkProphecy","ProphecySystem.WaitProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.EffectProphecy","ProphecySystem.WaitProphecy","ProphecySystem.ThemeProphecy","ProphecySystem.WaitProphecy","ProphecySystem.EffectProphecy","ProphecySystem.WaitProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.EmoteProphecy","ProphecySystem.WaitProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.EmoteProphecy","ProphecySystem.Talk